{
  "name": "ucf-brand-block-theme",
  "version": "0.1.0",
  "description": "Foundation-first block theme for UCF brand documentation.",
  "private": true,
  "license": "GPL-2.0-or-later",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build:blocks && npm run build:css",
    "build:blocks": "wp-scripts build --webpack-src-dir=blocks --output-path=build",
    "build:css": "sass src/scss/main.scss assets/css/main.css --style=compressed --no-source-map",
    "start": "wp-scripts start --webpack-src-dir=blocks --output-path=build",
    "watch": "sass --watch src/scss/main.scss assets/css/main.css --style=expanded",
    "lint:js": "wp-scripts lint-js blocks"
  },
  "devDependencies": {
    "@wordpress/scripts": "^30.0.0",
    "sass": "^1.100.0"
  }
}
