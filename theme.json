		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--text-body)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--body)",
			"lineHeight": "1.65"
		},
		"spacing": {
			"blockGap": "1rem"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "700",
					"letterSpacing": "0.01em",
					"lineHeight": "1.04",
					"textTransform": "uppercase"
				},
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "1rem"
					}
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--heading-1)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--heading-2)",
					"letterSpacing": "0.005em"
				},
				"spacing": {
					"margin": {
						"top": "var(--wp--preset--spacing--50)"
					}
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--heading-3)"
				},
				"spacing": {
					"margin": {
						"top": "var(--wp--preset--spacing--40)"
					}
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--heading-4)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--link-blue)"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--link-blue-hover)"
					},
					"typography": {
						"textDecoration": "underline"
					}
				},
				":focus": {
					"typography": {
						"textDecoration": "underline"
					}
				}
			},
			"button": {
				"border": {
					"radius": "0"
				},
				"color": {
					"background": "var(--wp--preset--color--gold)",
					"text": "var(--wp--preset--color--black)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--ui)",
					"fontWeight": "800",
					"letterSpacing": "0.02em",
					"textTransform": "uppercase"
				},
				"spacing": {
					"padding": {
						"top": "0.85rem",
						"right": "1.5rem",
						"bottom": "0.85rem",
						"left": "1.5rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--gold-deep)",
						"text": "var(--wp--preset--color--black)"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--gold-deep)",
						"text": "var(--wp--preset--color--black)"
					}
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--text-secondary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--meta)"
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--ui)",
					"fontWeight": "700"
				}
			},
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--ui)"
				}
			},
			"core/table": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--ui)"
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		},
		{
			"area": "uncategorized",
			"name": "brand-sidebar",
			"title": "Brand Sidebar"
		}
	]
}
