				{
					"color": "#8A2B1A",
					"name": "Danger",
					"slug": "danger"
				}
			]
		},
		"custom": {
			"textOnDark": "#EAEAEA",
			"sidebarWidth": "288px",
			"headerHeight": "50px",
			"wrap": "1160px"
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1160px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			],
			"spacingSizes": [
				{
					"size": "0.25rem",
					"name": "Tiny",
					"slug": "10"
				},
				{
					"size": "0.5rem",
					"name": "Small",
					"slug": "20"
				},
				{
					"size": "1rem",
					"name": "Medium",
					"slug": "30"
				},
				{
					"size": "1.5rem",
					"name": "Large",
					"slug": "40"
				},
				{
					"size": "3rem",
					"name": "Extra Large",
					"slug": "50"
				},
				{
					"size": "clamp(3.5rem, 7vw, 6rem)",
					"name": "Section",
					"slug": "60"
				}
			]
		},
		"typography": {
			"fluid": false,
			"customFontSize": false,
			"fontFamilies": [
				{
					"fontFamily": "'Oswald', 'Arial Narrow', sans-serif",
					"name": "Display",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Oswald",
							"fontWeight": "200 700",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"fontDisplay": "swap",
							"unicodeRange": "U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD",
							"src": [
								"file:./assets/fonts/oswald/oswald-variable-latin.woff2"
							]
						},
						{
							"fontFamily": "Oswald",
							"fontWeight": "200 700",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"fontDisplay": "swap",
							"unicodeRange": "U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF",
							"src": [
								"file:./assets/fonts/oswald/oswald-variable-latin-ext.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "'Montserrat', Arial, sans-serif",
					"name": "Body",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "Montserrat",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"fontDisplay": "swap",
							"unicodeRange": "U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD",
							"src": [
								"file:./assets/fonts/montserrat/montserrat-variable-latin.woff2"
							]
						},
						{
							"fontFamily": "Montserrat",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"fontDisplay": "swap",
							"unicodeRange": "U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF",
							"src": [
								"file:./assets/fonts/montserrat/montserrat-variable-latin-ext.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "'JetBrains Mono', 'Courier New', monospace",
					"name": "Mono",
					"slug": "mono",
					"fontFace": [
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "100 800",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"fontDisplay": "swap",
							"unicodeRange": "U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD",
							"src": [
								"file:./assets/fonts/jetbrains-mono/jetbrains-mono-variable-latin.woff2"
							]
						},
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "100 800",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"fontDisplay": "swap",
							"unicodeRange": "U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF",
							"src": [
								"file:./assets/fonts/jetbrains-mono/jetbrains-mono-variable-latin-ext.woff2"
							]
						}
					]
				}
