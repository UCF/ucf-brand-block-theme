				{
					"size": "0.68rem",
					"name": "Meta",
					"slug": "meta"
				},
				{
					"size": "0.72rem",
					"name": "Eyebrow",
					"slug": "eyebrow"
				},
				{
					"size": "0.86rem",
					"name": "UI",
					"slug": "ui"
				},
				{
					"size": "1rem",
					"name": "Body",
					"slug": "body"
				},
				{
					"size": "clamp(1.05rem, 1.7vw, 1.28rem)",
					"name": "Lead",
					"slug": "lead"
				},
				{
					"size": "1.28rem",
					"name": "Heading 4",
					"slug": "heading-4"
				},
				{
					"size": "clamp(1.3rem, 2.6vw, 1.9rem)",
					"name": "Heading 3",
					"slug": "heading-3"
				},
				{
					"size": "clamp(1.9rem, 3.6vw, 2.8rem)",
					"name": "Heading 2",
					"slug": "heading-2"
				},
				{
					"size": "clamp(2.4rem, 5vw, 4.2rem)",
					"name": "Heading 1",
					"slug": "heading-1"
				},
				{
